# Digital Fortress Backend .env example
# Copy to backend/.env and update values as needed

APP_NAME=Digital Fortress API
APP_ENV=dev
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/digital_fortress

# Redis
REDIS_URL=redis://localhost:6379/0
EVENT_CHANNEL=digital-fortress.events

# Nuclei Scanner
NUCLEI_USE_DOCKER=True
NUCLEI_DOCKER_CONTAINER=df-nuclei

# JWT Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# Compliance
COMPLIANCE_MODE_DEFAULT=True
REQUIRE_TENANT_HEADER=True

# BunkerWeb API
BUNKERWEB_API_URL=http://bunkerweb:8080/api/v1
BUNKERWEB_API_KEY=change-me
BUNKERWEB_API_TIMEOUT=10
